{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "env": {
    "APP_KEY": "base64:HLBhaq3JwlhcBUESV872UMq1MnKK5N3/NkN6Mkh0Z20=",
    "APP_ENV": "production",
    "APP_DEBUG": "true",
    "APP_CONFIG_CACHE": "/tmp/config.php",
    "APP_EVENTS_CACHE": "/tmp/events.php",
    "APP_PACKAGES_CACHE": "/tmp/packages.php",
    "APP_ROUTES_CACHE": "/tmp/routes.php",
    "APP_SERVICES_CACHE": "/tmp/services.php",
    "VIEW_COMPILED_PATH": "/tmp/views",
    "CACHE_STORE": "array",
    "CACHE_DRIVER": "array",
    "SESSION_DRIVER": "cookie",
    "LOG_CHANNEL": "stderr"
  },
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/build/$1"
    },
    {
      "src": "/(POSTER|about-bahan|bahan|image-sequence|menu|referensi)/(.*)",
      "dest": "/$1/$2"
    },
    {
      "src": "/(favicon.ico|favicon.svg|robots.txt|apple-touch-icon.png)",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "outputDirectory": "public"
}
