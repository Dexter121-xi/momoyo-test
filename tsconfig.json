{
    "compilerOptions": {
        /* Visit https://aka.ms/tsconfig to read more about this file */

        /* Language and Environment */
        "target": "ESNext",
        "jsx": "react-jsx",

        /* Modules */
        "module": "ESNext",
        "moduleResolution": "bundler",
        
        /* AKTIFKAN INI agar TypeScript mengizinkan import file .tsx tanpa error */
        "allowImportingTsExtensions": true,               

        /* JavaScript Support */
        "allowJs": true,

        /* Emit */
        "noEmit": true,

        /* Interop Constraints */
        "isolatedModules": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,

        /* Type Checking */
        "strict": true,
        "noImplicitAny": true,

        /* Completeness */
        "skipLibCheck": true,
        
        /* Path Mapping (Alias @/) */
        "baseUrl": ".",
        "paths": {
            "@/*": ["./resources/js/*"]
        }
    },
    "include": [
        "resources/js/**/*.ts",
        "resources/js/**/*.d.ts",
        "resources/js/**/*.tsx"
    ]
}
